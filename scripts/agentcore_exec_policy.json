{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeWaiverToolLambdas",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": [
        "arn:aws:lambda:${REGION}:${ACCT}:function:waiver-start-workflow",
        "arn:aws:lambda:${REGION}:${ACCT}:function:waiver-update-state",
        "arn:aws:lambda:${REGION}:${ACCT}:function:waiver-get-state"
      ]
    },
    { "Sid": "SendEmail", "Effect": "Allow", "Action": ["ses:SendEmail", "ses:SendRawEmail"], "Resource": "*" },
    { "Sid": "ReadCriteria", "Effect": "Allow", "Action": ["s3:GetObject", "s3:ListBucket"], "Resource": [
        "arn:aws:s3:::${CRITERIA_BUCKET}",
        "arn:aws:s3:::${CRITERIA_BUCKET}/*"
    ]},
    { "Sid": "InvokeNova", "Effect": "Allow", "Action": ["bedrock:InvokeModel", "bedrock:InvokeModelWithResponseStream"], "Resource": [
        "arn:aws:bedrock:*::foundation-model/amazon.nova-pro-v1:0",
        "arn:aws:bedrock:${REGION}:${ACCT}:inference-profile/eu.amazon.nova-pro-v1:0"
    ]},
    { "Sid": "ApplyGuardrail", "Effect": "Allow", "Action": "bedrock:ApplyGuardrail", "Resource": "arn:aws:bedrock:${REGION}:${ACCT}:guardrail/${GUARDRAIL_ID}" }
  ]
}
